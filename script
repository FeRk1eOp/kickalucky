-- Эффективная видимость GuiObject: учитываем все родительские Visible/Enabled.
local function isEffectivelyVisible(gui)
    local cur = gui
    while cur and cur ~= game do
        if cur:IsA("ScreenGui") then
            return cur.Enabled
        elseif cur:IsA("GuiObject") then
            if cur.Visible == false then return false end
        end
        cur = cur.Parent
    end
    return true
end

-- Нажатие на GuiButton через все доступные API эксплоитов, чтобы работало в разных.
local function clickGuiButton(btn)
    if not btn then return end
    local signals = { btn.Activated, btn.MouseButton1Click, btn.MouseButton1Down, btn.MouseButton1Up }
    for _, sig in ipairs(signals) do
        pcall(function()
            if firesignal then firesignal(sig) end
        end)
    end
    pcall(function()
        if getconnections then
            for _, sig in ipairs(signals) do
                for _, conn in ipairs(getconnections(sig)) do
                    if conn.Fire then
                        pcall(function() conn:Fire() end)
                    elseif conn.Function then
                        pcall(conn.Function)
                    end
                end
            end
        end
    end)
end

local autoBonusLoopRunning = false
local function autoBonusLoop()
    if autoBonusLoopRunning then return end
    autoBonusLoopRunning = true
    while ScriptSettings.AutoBonusEnabled do
        local ku = getKickUpgradesOrNil()
        if ku then
            -- Брутфорс: жмём все GuiButton под KickUpgrades, которые реально видны и Active.
            -- Фейковая кнопка-приманка обычно либо скрыта, либо не имеет рабочего обработчика.
            for _, d in ipairs(ku:GetDescendants()) do
                if d:IsA("GuiButton") and d.Active and isEffectivelyVisible(d) then
                    clickGuiButton(d)
                end
            end
        end
        task.wait(0.3)
    end
    autoBonusLoopRunning = false
end

