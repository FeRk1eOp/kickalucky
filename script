--[[
    Brainrot AutoFarm для Kick a Lucky Block
    - Перемещение ВСЕГО персонажа через SetPrimaryPartCFrame
    - Подъём на 6 единиц выше Safe (можно изменить переменную verticalOffset)
--]]

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Network = ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Packages"):WaitForChild("Network")
local rev_KickEvent = Network:WaitForChild("rev_KickEvent")

local player = Players.LocalPlayer
local safePart = workspace:WaitForChild("Lobby"):WaitForChild("Safe")

local isEnabled = false
local isCycling = false
local firstRun = true

-- НАСТРОЙКА: на сколько выше поднимать игрока (в студиях)
local verticalOffset = 6   -- было 3, теперь 6, можно поставить хоть 10

-- Целевая позиция выше Safe
local function getTargetCFrame()
    return safePart.CFrame + Vector3.new(0, verticalOffset, 0)
end

-- Мгновенный теп ВСЕГО персонажа
local function teleportWholeCharacter(character)
    if not character or not character.PrimaryPart then
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then character.PrimaryPart = hrp end
        end
        if not character or not character.PrimaryPart then return end
    end
    character:SetPrimaryPartCFrame(getTargetCFrame())
    print("[Brainrot] Мгновенный теп в Safe (выше на " .. verticalOffset .. ")")
end

-- Плавное перемещение ВСЕГО персонажа с интерполяцией
local function smoothTeleportCharacter(character, duration)
    if not character or not character.PrimaryPart then
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then character.PrimaryPart = hrp end
        end
        if not character or not character.PrimaryPart then return false end
    end

    local targetCF = getTargetCFrame()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local wasPlatformStand = humanoid and humanoid.PlatformStand or false
    local wasAutoRotate = humanoid and humanoid.AutoRotate or false

    if humanoid then
        humanoid.PlatformStand = true
        humanoid.AutoRotate = false
    end

    local startCFrame = character.PrimaryPart.CFrame
    local startTime = tick()

    while tick() - startTime < duration do
        local alpha = (tick() - startTime) / duration
        local newCFrame = startCFrame:Lerp(targetCF, alpha)
        character:SetPrimaryPartCFrame(newCFrame)
        task.wait()
    end

    character:SetPrimaryPartCFrame(targetCF)

    if humanoid then
        humanoid.PlatformStand = wasPlatformStand
        humanoid.AutoRotate = wasAutoRotate
    end
    print("[Brainrot] Плавное перемещение завершено (выше на " .. verticalOffset .. ")")
    return true
end

-- Проверка: достаточно близко к целевой позиции (с учётом высоты)
local function isAtSafe(character)
    if not character or not character.PrimaryPart then return false end
    local targetPos = getTargetCFrame().Position
    local dist = (character.PrimaryPart.Position - targetPos).Magnitude
    return dist < 5
end

-- Ожидание появления персонажа
local function waitForCharacter()
    local char = player.Character
    if not char or not char.PrimaryPart then
        char = player.CharacterAdded:Wait()
        repeat task.wait() until char.PrimaryPart or char:FindFirstChild("HumanoidRootPart")
        if char and not char.PrimaryPart then
            char.PrimaryPart = char:FindFirstChild("HumanoidRootPart")
        end
        print("[Brainrot] Новая модель персонажа загружена")
    end
    return char
end

-- Основной цикл
local function farmLoop()
    while isEnabled do
        if isCycling then
            task.wait(0.2)
            continue
        end
        isCycling = true

        local character = waitForCharacter()

        if firstRun then
            if not isAtSafe(character) then
                teleportWholeCharacter(character)
                task.wait(0.3)
            end
            firstRun = false
        end

        if not isAtSafe(character) then
            print("[Brainrot] Персонаж не в Safe, ждём...")
            isCycling = false
            task.wait(0.5)
            continue
        end

        -- Пинок
        local args = { [1] = 1 }
        rev_KickEvent:FireServer(unpack(args))
        print("[Brainrot] KickEvent отправлен, ждём 14 секунд...")

        task.wait(14)

        local currentChar = waitForCharacter()
        smoothTeleportCharacter(currentChar, 2)   -- плавно за 2 секунды

        isCycling = false
    end
end

-- ========== МЕНЮ ==========
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "BrainrotFarmGUI"
screenGui.Parent = player:WaitForChild("PlayerGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 220, 0, 110)
mainFrame.Position = UDim2.new(0, 15, 0, 15)
mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
mainFrame.BackgroundTransparency = 0.4
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

local toggleBtn = Instance.new("TextButton")
toggleBtn.Size = UDim2.new(0, 200, 0, 40)
toggleBtn.Position = UDim2.new(0, 10, 0, 10)
toggleBtn.Text = "▶ Включить фарм"
toggleBtn.TextColor3 = Color3.new(1, 1, 1)
toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
toggleBtn.BorderSizePixel = 0
toggleBtn.Parent = mainFrame

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(0, 200, 0, 30)
statusLabel.Position = UDim2.new(0, 10, 0, 65)
statusLabel.Text = "Статус: ● Выключен"
statusLabel.TextColor3 = Color3.new(1, 1, 1)
statusLabel.BackgroundTransparency = 1
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.Parent = mainFrame

toggleBtn.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    if isEnabled then
        toggleBtn.Text = "⏹ Выключить фарм"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        statusLabel.Text = "Статус: ● Включён"
        firstRun = true
        isCycling = false
        task.spawn(farmLoop)
    else
        toggleBtn.Text = "▶ Включить фарм"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
        statusLabel.Text = "Статус: ● Выключен"
        isCycling = false
    end
end)
