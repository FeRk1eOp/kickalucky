local function getTargetCFrame()
    return safePart.CFrame + Vector3.new(0, FarmSettings.VerticalOffset, 0)
end

local function teleportWholeCharacter(character)
    if not character or not character.PrimaryPart then
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then character.PrimaryPart = hrp end
        end
        if not character or not character.PrimaryPart then return end
    end
    character:SetPrimaryPartCFrame(getTargetCFrame())
end

local function smoothTeleportCharacter(character, duration)
    if not character or not character.PrimaryPart then
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then character.PrimaryPart = hrp end
        end
        if not character or not character.PrimaryPart then return false end
    end

    local targetCF = getTargetCFrame()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local wasPlatformStand = humanoid and humanoid.PlatformStand or false
    local wasAutoRotate = humanoid and humanoid.AutoRotate or false

    if humanoid then
        humanoid.PlatformStand = true
        humanoid.AutoRotate = false
    end

    local startCFrame = character.PrimaryPart.CFrame
    local startTime = tick()

    while tick() - startTime < duration do
        local alpha = (tick() - startTime) / duration
        local newCFrame = startCFrame:Lerp(targetCF, alpha)
        character:SetPrimaryPartCFrame(newCFrame)
        task.wait()
    end

    character:SetPrimaryPartCFrame(targetCF)

    if humanoid then
        humanoid.PlatformStand = wasPlatformStand
        humanoid.AutoRotate = wasAutoRotate
    end
    return true
end

local function isAtSafe(character)
    if not character or not character.PrimaryPart then return false end
    local targetPos = getTargetCFrame().Position
    local dist = (character.PrimaryPart.Position - targetPos).Magnitude
    return dist < 5
end

local function waitForCharacter()
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then
        char = LocalPlayer.CharacterAdded:Wait()
        repeat task.wait() until char.PrimaryPart or char:FindFirstChild("HumanoidRootPart")
        if char and not char.PrimaryPart then
            char.PrimaryPart = char:FindFirstChild("HumanoidRootPart")
        end
    end
    return char
end

-- The actual farming loop
local function farmCycle()
    while isFarming do
        local character = waitForCharacter()

        if firstRun then
            if not isAtSafe(character) then
                teleportWholeCharacter(character)
                task.wait(0.3)
            end
            firstRun = false
        end

        if not isAtSafe(character) then
            task.wait(0.5)
            continue
        end

        -- Kick the Lucky Block
        local args = { [1] = 1 }
        rev_KickEvent:FireServer(unpack(args))

        -- Wait for brainrot animation
        task.wait(FarmSettings.WaitSeconds)

        local currentChar = waitForCharacter()
        smoothTeleportCharacter(currentChar, 2)

        task.wait(0.5)
    end
end

local function setFarming(enabled)
    if enabled == isFarming then return end
    isFarming = enabled
    if enabled then
        firstRun = true
        if farmingThread then coroutine.close(farmingThread) end
        farmingThread = coroutine.create(farmCycle)
        coroutine.resume(farmingThread)
    else
        if farmingThread then coroutine.close(farmingThread); farmingThread = nil end
    end

    -- Update GUI immediately
    if farmToggleBtn and farmStatusLabel then
        if isFarming then
            farmToggleBtn.Text = "⏹ Disable Farm"
            farmToggleBtn.BackgroundColor3 = Color3.fromRGB(180,0,0)
            farmStatusLabel.Text = "Status: ● Enabled (working in Safe)"
        else
            farmToggleBtn.Text = "▶ Enable Farm"
            farmToggleBtn.BackgroundColor3 = COLORS.Button
            farmStatusLabel.Text = "Status: ○ Disabled"
        end
    end
end

