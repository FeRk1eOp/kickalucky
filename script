-- Dragging (mobile + PC)
local dragActive = false
local dragStartPos, startFramePos
DragBar.MouseButton1Down:Connect(function()
    dragActive = true
    dragStartPos = Vector2.new(Mouse.X, Mouse.Y)
    startFramePos = MainFrame.Position
end)
UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragActive then
        local delta = Vector2.new(Mouse.X, Mouse.Y) - dragStartPos
        MainFrame.Position = UDim2.new(startFramePos.X.Scale, startFramePos.X.Offset + delta.X, startFramePos.Y.Scale, startFramePos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragActive = false end
end)
if UserInputService.TouchEnabled then
    UserInputService.TouchBegan:Connect(function(touch)
        local pos = touch.Position
        local abs = DragBar.AbsolutePosition
        local size = DragBar.AbsoluteSize
        if pos.X >= abs.X and pos.X <= abs.X+size.X and pos.Y >= abs.Y and pos.Y <= abs.Y+size.Y then
            dragActive = true
            dragStartPos = pos
            startFramePos = MainFrame.Position
        end
    end)
    UserInputService.TouchMoved:Connect(function(touch)
        if dragActive then
            local delta = touch.Position - dragStartPos
            MainFrame.Position = UDim2.new(startFramePos.X.Scale, startFramePos.X.Offset + delta.X, startFramePos.Y.Scale, startFramePos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.TouchEnded:Connect(function() dragActive = false end)
end

-- Toggle menu with RightShift
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == SETTINGS.ToggleKey then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

