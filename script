createBtn.MouseButton1Click:Connect(function()
    local n = nameBox.Text:gsub("^%s*(.-)%s*$","%1")
    if n == "" then notify("Enter a name", true) return end
    if createConfig(n) then
        notify("Config '"..n.."' saved", true)
        if refreshList then refreshList() end
        nameBox.Text = ""
    else
        notify("Save failed", true)
    end
end)

refreshList = function()
    for _, ch in ipairs(listFrame:GetChildren()) do
        if ch:IsA("TextButton") or ch:IsA("TextLabel") then ch:Destroy() end
    end
    local cfgs = listCfgs()
    local autoName = getAuto()
    if #cfgs == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size              = UDim2.new(1,-10,0,30)
        empty.BackgroundTransparency = 1
        empty.Text              = "No saved configs"
        empty.TextColor3        = COLORS.TextDark
        empty.Font              = Enum.Font.Gotham
        empty.TextSize          = 13
        empty.Parent            = listFrame
    else
        for _, cfg in ipairs(cfgs) do
            local b = Instance.new("TextButton")
            b.Size              = UDim2.new(1,-10,0,30)
            b.Text              = cfg .. (autoName == cfg and " [AUTOLOAD]" or "")
            b.BackgroundColor3  = (cfg == selectedConfig) and COLORS.ButtonSelected or COLORS.Button
            b.TextColor3        = COLORS.Text
            b.Font              = Enum.Font.Gotham
            b.TextSize          = 13
            b.AutoButtonColor   = false
            b.Parent            = listFrame
            local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0,4) c.Parent = b
            b.MouseEnter:Connect(function()
                if cfg ~= selectedConfig then b.BackgroundColor3 = COLORS.ButtonSelected end
            end)
            b.MouseLeave:Connect(function()
                if cfg ~= selectedConfig then b.BackgroundColor3 = COLORS.Button end
            end)
            b.MouseButton1Click:Connect(function()
                selectedLabel.Text = "Selected: " .. cfg
                selectedConfig     = cfg
                for _, child in ipairs(listFrame:GetChildren()) do
                    if child:IsA("TextButton") then
                        child.BackgroundColor3 = COLORS.Button
                    end
                end
                b.BackgroundColor3 = COLORS.ButtonSelected
            end)
        end
    end
end

loadBtn.MouseButton1Click:Connect(function()
    if selectedConfig then
        if loadConfig(selectedConfig) then
            notify("Config '"..selectedConfig.."' loaded", true)
            refreshList()
        else
            notify("Load failed", true)
        end
    else
        notify("Select a config", true)
    end
end)

setAutoBtn.MouseButton1Click:Connect(function()
    if selectedConfig then
        setAuto(selectedConfig)
        notify("Autoload set to "..selectedConfig, true)
        refreshList()
    else
        notify("Select a config", true)
    end
end)

delAutoBtn.MouseButton1Click:Connect(function()
    delAuto()
    notify("Autoload removed", true)
    refreshList()
end)

delConfigBtn.MouseButton1Click:Connect(function()
    if selectedConfig then
        if delCfg(selectedConfig) then
            notify("Config '"..selectedConfig.."' deleted", true)
            if getAuto() == selectedConfig then delAuto() end
            selectedConfig = nil
            selectedLabel.Text = "Selected: -"
            refreshList()
        else
            notify("Delete failed", true)
        end
    else
        notify("Select a config", true)
    end
end)

refreshList()

