-- ========== DRAG SUPPORT (PC + MOBILE) ==========
local dragData = { active = false, startPos = Vector2.zero, startFramePos = UDim2.new() }

local function onDragStart(inputPos)
    dragData.active = true
    dragData.startPos = inputPos
    dragData.startFramePos = MainFrame.Position
end

local function onDragMove(inputPos)
    if not dragData.active then return end
    local delta = inputPos - dragData.startPos
    MainFrame.Position = UDim2.new(
        dragData.startFramePos.X.Scale,
        dragData.startFramePos.X.Offset + delta.X,
        dragData.startFramePos.Y.Scale,
        dragData.startFramePos.Y.Offset + delta.Y
    )
end

local function onDragEnd()
    dragData.active = false
end

-- Mouse
DragBar.MouseButton1Down:Connect(function()
    onDragStart(Vector2.new(Mouse.X, Mouse.Y))
end)
UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragData.active then
        onDragMove(Vector2.new(Mouse.X, Mouse.Y))
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        onDragEnd()
    end
end)
Mouse.Button1Up:Connect(onDragEnd)

-- Touch
if UserInputService.TouchEnabled then
    local function touchBegan(touch, gameProcessed)
        if gameProcessed then return end
        local dragBarAbsPos = DragBar.AbsolutePosition
        local dragBarSize = DragBar.AbsoluteSize
        if touch.Position.X >= dragBarAbsPos.X and touch.Position.X <= dragBarAbsPos.X + dragBarSize.X and
           touch.Position.Y >= dragBarAbsPos.Y and touch.Position.Y <= dragBarAbsPos.Y + dragBarSize.Y then
            onDragStart(touch.Position)
        end
    end
    local function touchMoved(touch, gameProcessed)
        if gameProcessed then return end
        onDragMove(touch.Position)
    end
    local function touchEnded(touch, gameProcessed)
        onDragEnd()
    end
    UserInputService.TouchBegan:Connect(touchBegan)
    UserInputService.TouchMoved:Connect(touchMoved)
    UserInputService.TouchEnded:Connect(touchEnded)
end

