local useFS = pcall(function() return isfolder and makefolder and listfiles and writefile and readfile and delfile end)
local globalCfgs = getgenv()._Fer4ixzConfigs or {}
getgenv()._Fer4ixzConfigs = globalCfgs

local function saveCfg(name, data)
    if useFS then
        local folder = "Fer4ixzConfigs"
        if not isfolder(folder) then makefolder(folder) end
        return pcall(writefile, folder.."/"..name..".json", HttpService:JSONEncode(data))
    else
        globalCfgs[name] = data
        return true
    end
end

local function loadCfg(name)
    if useFS then
        local folder = "Fer4ixzConfigs"
        local ok, cont = pcall(readfile, folder.."/"..name..".json")
        if ok and cont then return HttpService:JSONDecode(cont) end
        return nil
    else
        return globalCfgs[name]
    end
end

local function listCfgs()
    if useFS then
        local folder = "Fer4ixzConfigs"
        if not isfolder(folder) then return {} end
        local files = listfiles(folder)
        local names = {}
        for _, f in ipairs(files) do
            local n = f:match("([^/\\]+)%.json$")
            if n then table.insert(names, n) end
        end
        return names
    else
        local names = {}
        for n in pairs(globalCfgs) do table.insert(names, n) end
        return names
    end
end

local function delCfg(name)
    if useFS then
        local folder = "Fer4ixzConfigs"
        return pcall(delfile, folder.."/"..name..".json")
    else
        globalCfgs[name] = nil
        return true
    end
end

local function getAuto()
    if useFS then
        local folder = "Fer4ixzConfigs"
        if isfolder(folder) and isfile(folder.."/autoload.txt") then
            local n = readfile(folder.."/autoload.txt"):gsub("\n","")
            if n ~= "" then
                for _, c in ipairs(listCfgs()) do if c == n then return n end end
            end
        end
        return nil
    else
        return getgenv()._Fer4ixzAutoload
    end
end

local function setAuto(name)
    if useFS then
        local folder = "Fer4ixzConfigs"
        if not isfolder(folder) then makefolder(folder) end
        writefile(folder.."/autoload.txt", name)
    else
        getgenv()._Fer4ixzAutoload = name
    end
end

local function delAuto()
    if useFS then
        local folder = "Fer4ixzConfigs"
        if isfolder(folder) and isfile(folder.."/autoload.txt") then delfile(folder.."/autoload.txt") end
    else
        getgenv()._Fer4ixzAutoload = nil
    end
end

local function createConfig(name)
    if name == nil or name == "" then return false end
    local data = { version = 1 }
    return saveCfg(name, data)
end

local function loadConfig(name)
    local data = loadCfg(name)
    if not data then return false end
    return true
end

