    local corner = Instance.new("UICorner") corner.CornerRadius = UDim.new(0,6) corner.Parent = btn

    local iconFrame = Instance.new("Frame")
    iconFrame.Size                  = UDim2.new(1,0,1,0)
    iconFrame.BackgroundTransparency = 1
    iconFrame.ZIndex                = 6
    iconFrame.Parent                = btn

    if iconType == "Close" then
        local line1 = Instance.new("Frame")
        line1.Size              = UDim2.new(0, 18, 0, 4)
        line1.Position          = UDim2.new(0.5, -9, 0.5, -2)
        line1.Rotation          = 45
        line1.BackgroundColor3  = Color3.fromRGB(255, 80, 80)
        line1.BorderSizePixel   = 0
        line1.ZIndex            = 7
        line1.Parent            = iconFrame
        local c1 = Instance.new("UICorner") c1.CornerRadius = UDim.new(0,2) c1.Parent = line1
        local line2 = line1:Clone()
        line2.Rotation = -45
        line2.Parent   = iconFrame
        btn.MouseEnter:Connect(function()
            line1.BackgroundColor3 = Color3.fromRGB(255,120,120)
            line2.BackgroundColor3 = Color3.fromRGB(255,120,120)
            btn.BackgroundColor3   = Color3.fromRGB(50,50,50)
        end)
        btn.MouseLeave:Connect(function()
            line1.BackgroundColor3 = Color3.fromRGB(255,80,80)
            line2.BackgroundColor3 = Color3.fromRGB(255,80,80)
            btn.BackgroundColor3   = COLORS.Button
        end)
    elseif iconType == "Minimize" then
        local line = Instance.new("Frame")
        line.Size              = UDim2.new(0, 18, 0, 4)
        line.Position          = UDim2.new(0.5, -9, 0.5, 0)
        line.BackgroundColor3  = Color3.fromRGB(200, 200, 200)
