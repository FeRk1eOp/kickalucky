-- Tabs
local tabs = {}
local function CreateTab(name, title)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,0,36)
    btn.BackgroundColor3 = COLORS.Button
    btn.Text = title
    btn.TextColor3 = COLORS.TextDark
    btn.Font = Enum.Font.GothamMedium
    btn.TextSize = 14
    btn.Parent = BtnContainer
    local corner = Instance.new("UICorner") corner.CornerRadius = UDim.new(0,6) corner.Parent = btn

    local page = Instance.new("Frame")
    page.Size = UDim2.new(1,0,1,0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.Parent = Content

    btn.MouseButton1Click:Connect(function()
        for _, t in pairs(tabs) do
            t.btn.BackgroundColor3 = COLORS.Button
            t.btn.TextColor3 = COLORS.TextDark
            t.page.Visible = false
        end
        btn.BackgroundColor3 = COLORS.ButtonSelected
        btn.TextColor3 = COLORS.Text
        page.Visible = true
    end)

    tabs[name] = {btn = btn, page = page}
    return page
end

local homeTab = CreateTab("Home", "Home")
local mainTab = CreateTab("Main", "Main")

local label1 = Instance.new("TextLabel")
