local toggleRegistry = {}
local function CreateToggle(parent, name, defaultVal, onFunc, offFunc)
    local container = Instance.new("Frame")
    container.Size              = UDim2.new(1,0,0,45)
    container.BackgroundColor3  = COLORS.Sidebar
    container.BackgroundTransparency = 0.5
    container.Parent            = parent
    local corner = Instance.new("UICorner") corner.CornerRadius = UDim.new(0,6) corner.Parent = container

    local label = Instance.new("TextLabel")
    label.Size              = UDim2.new(0.7,0,1,0)
    label.Position          = UDim2.new(0,10,0,0)
    label.BackgroundTransparency = 1
    label.Text              = name
    label.TextColor3        = COLORS.Text
    label.Font              = Enum.Font.GothamMedium
    label.TextSize          = 14
    label.TextXAlignment    = Enum.TextXAlignment.Left
    label.Parent            = container

    local sw = Instance.new("TextButton")
    sw.Text             = ""
    sw.Size             = UDim2.new(0,45,0,25)
    sw.Position         = UDim2.new(1,-55,0.5,-12)
    sw.BackgroundColor3 = defaultVal and Color3.fromRGB(50,200,50) or COLORS.Button
    sw.BorderSizePixel  = 0
    sw.AutoButtonColor  = false
    sw.Parent           = container
    local swCorner = Instance.new("UICorner") swCorner.CornerRadius = UDim.new(1,0) swCorner.Parent = sw

    local handle = Instance.new("Frame")
    handle.Size              = UDim2.new(0,20,0,20)
    handle.BackgroundColor3  = COLORS.Text
    handle.BorderSizePixel   = 0
    handle.Parent            = sw
    local hCorner = Instance.new("UICorner") hCorner.CornerRadius = UDim.new(1,0) hCorner.Parent = handle

    local active   = defaultVal
    local posOn    = UDim2.new(1,-22,0.5,-10)
    local posOff   = UDim2.new(0,2,0.5,-10)
    handle.Position = active and posOn or posOff

    local function updateVis()
        local targetColor = active and Color3.fromRGB(50,200,50) or COLORS.Button
        local targetPos   = active and posOn or posOff
        TweenService:Create(sw,     TweenInfo.new(0.15), {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(handle, TweenInfo.new(0.15), {Position = targetPos}):Play()
    end

    local function setValue(v, silent)
        if active == v then return end
        active = v
        updateVis()
        if not silent then
            if active then pcall(onFunc) else pcall(offFunc) end
        end
    end

    sw.MouseButton1Click:Connect(function() setValue(not active) end)
    if defaultVal then updateVis() end
    toggleRegistry[name] = setValue
    return { setValue = setValue, getValue = function() return active end }
end

local stepperRegistry = {}
local function CreateStepper(parent, labelText, minVal, maxVal, step, defaultValue, onChange)
    local container = Instance.new("Frame")
    container.Size              = UDim2.new(1,0,0,35)
    container.BackgroundTransparency = 1
    container.Parent            = parent

    local label = Instance.new("TextLabel")
    label.Size              = UDim2.new(0.6,0,1,0)
    label.Position          = UDim2.new(0,5,0,0)
    label.BackgroundTransparency = 1
    label.Text              = labelText .. defaultValue
    label.TextColor3        = COLORS.Text
    label.Font              = Enum.Font.Gotham
    label.TextSize          = 12
    label.TextXAlignment    = Enum.TextXAlignment.Left
    label.Parent            = container

    local minus = Instance.new("TextButton")
    minus.Size              = UDim2.new(0,30,0,25)
    minus.Position          = UDim2.new(0.65,0,0.5,-12)
    minus.Text              = "-"
    minus.BackgroundColor3  = COLORS.Button
    minus.TextColor3        = COLORS.Text
    minus.Font              = Enum.Font.GothamBold
    minus.Parent            = container
    local minusCorner = Instance.new("UICorner") minusCorner.CornerRadius = UDim.new(0,4) minusCorner.Parent = minus

    local valLabel = Instance.new("TextLabel")
    valLabel.Size              = UDim2.new(0,50,0,25)
    valLabel.Position          = UDim2.new(0.75,0,0.5,-12)
    valLabel.BackgroundColor3  = COLORS.Button
    valLabel.Text              = tostring(defaultValue)
    valLabel.TextColor3        = COLORS.Text
    valLabel.Font              = Enum.Font.Gotham
    valLabel.TextSize          = 12
    valLabel.Parent            = container
    local valCorner = Instance.new("UICorner") valCorner.CornerRadius = UDim.new(0,4) valCorner.Parent = valLabel

    local plus = Instance.new("TextButton")
    plus.Size              = UDim2.new(0,30,0,25)
    plus.Position          = UDim2.new(0.85,0,0.5,-12)
    plus.Text              = "+"
    plus.BackgroundColor3  = COLORS.Button
    plus.TextColor3        = COLORS.Text
    plus.Font              = Enum.Font.GothamBold
    plus.Parent            = container
    local plusCorner = Instance.new("UICorner") plusCorner.CornerRadius = UDim.new(0,4) plusCorner.Parent = plus

    local current = math.clamp(defaultValue, minVal, maxVal)

    local function updateUI()
        if step >= 1 then
            valLabel.Text = string.format("%d", current)
        else
            valLabel.Text = string.format("%.1f", current)
        end
        label.Text = labelText .. current
    end

    local function setValue(v, silent)
        v = math.clamp(v, minVal, maxVal)
        if math.abs(v - current) > 0.001 then
            current = v
            updateUI()
            if not silent and onChange then onChange(current) end
        end
    end

    minus.MouseButton1Click:Connect(function() setValue(current - step) end)
    plus.MouseButton1Click:Connect(function() setValue(current + step) end)
    updateUI()
    local api = { setValue = setValue, getValue = function() return current end }
    stepperRegistry[labelText] = api
    return api
end

