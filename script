local function getSafePartOrNil()
    local lobby = workspace:FindFirstChild("Lobby")
    if not lobby then return nil end
    return lobby:FindFirstChild("Safe")
end

local function getTargetCFrame()
    local safePart = getSafePartOrNil()
    if not safePart then return nil end
    return safePart.CFrame + Vector3.new(0, ScriptSettings.VerticalOffset, 0)
end

local function ensurePrimaryPart(character)
    if not character then return false end
    if character.PrimaryPart then return true end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then
        character.PrimaryPart = hrp
        return true
    end
    return false
end

-- Обнулить линейную/угловую скорость HRP, чтобы персонажа не сносило
-- остаточным импульсом после телепорта / Knock.
local function zeroVelocity(part)
    if not part then return end
    pcall(function() part.AssemblyLinearVelocity  = Vector3.zero end)
    pcall(function() part.AssemblyAngularVelocity = Vector3.zero end)
    pcall(function() part.Velocity    = Vector3.new(0, 0, 0) end)
    pcall(function() part.RotVelocity = Vector3.new(0, 0, 0) end)
end

local function teleportWholeCharacter(character)
    if not ensurePrimaryPart(character) then return end
    local target = getTargetCFrame()
    if not target then return end
    character:SetPrimaryPartCFrame(target)
    zeroVelocity(character.PrimaryPart)
    print(("[Brainrot] Мгновенный теп в Safe (выше на %d)"):format(ScriptSettings.VerticalOffset))
end

local function smoothTeleportCharacter(character, duration)
    if not ensurePrimaryPart(character) then return false end
    local target = getTargetCFrame()
    if not target then return false end

    local hrp               = character.PrimaryPart
    local humanoid          = character:FindFirstChildOfClass("Humanoid")
    local wasPlatformStand  = humanoid and humanoid.PlatformStand or false
    local wasAutoRotate     = humanoid and humanoid.AutoRotate or false
    local wasAnchored       = hrp.Anchored

    if humanoid then
        humanoid.PlatformStand = true
        humanoid.AutoRotate    = false
    end
    -- Анкорим HRP, чтобы физика не стаскивала персонажа в сторону
    -- пока идёт плавный возврат.
    hrp.Anchored = true
    zeroVelocity(hrp)

    local startCFrame = hrp.CFrame
    local startTime   = tick()
    duration          = math.max(duration or 0, 0.05)

    while tick() - startTime < duration do
        if not ScriptSettings.AutoFarmEnabled then break end
        local alpha = (tick() - startTime) / duration
        local newCFrame = startCFrame:Lerp(target, alpha)
        character:SetPrimaryPartCFrame(newCFrame)
        task.wait()
    end

    if character.PrimaryPart then
        character:SetPrimaryPartCFrame(target)
        zeroVelocity(character.PrimaryPart)
    end

    if character.PrimaryPart then
        character.PrimaryPart.Anchored = wasAnchored
    end
    if humanoid then
        humanoid.PlatformStand = wasPlatformStand
        humanoid.AutoRotate    = wasAutoRotate
    end
    print(("[Brainrot] Плавное перемещение завершено (выше на %d)"):format(ScriptSettings.VerticalOffset))
    return true
end

-- Снапнуть персонажа ровно на верхнюю грань Safe (без verticalOffset),
-- чтобы в момент вызова KickEvent персонаж был физически на платформе,
-- а не в воздухе после плавного возврата.
local function snapToSafeSurface(character)
    if not ensurePrimaryPart(character) then return false end
    local safePart = getSafePartOrNil()
    if not safePart then return false end
    local pos     = safePart.Position + Vector3.new(0, safePart.Size.Y / 2 + 2, 0)
    local current = character.PrimaryPart.CFrame
    -- Сохраняем ориентацию, меняем только позицию.
    character:SetPrimaryPartCFrame(current + (pos - current.Position))
    zeroVelocity(character.PrimaryPart)
    return true
end

-- Проверка: игрок стоит на/над Safe (по XZ-проекции колонны Safe + допуск по Y).
-- Использует размер Safe, чтобы корректно работать на любой толщине платформы,
-- а не только когда игрок ровно в 5 студах от точки (Safe + offset).
local function isAtSafe(character)
    if not character or not character.PrimaryPart then return false end
    local safePart = getSafePartOrNil()
    if not safePart then return false end

    local charPos = character.PrimaryPart.Position
    local safePos = safePart.Position
    local size    = safePart.Size

    -- XZ: внутри (или почти внутри) границ верхней грани Safe.
    local dx = math.abs(charPos.X - safePos.X)
    local dz = math.abs(charPos.Z - safePos.Z)
    if dx > size.X / 2 + 5 then return false end
    if dz > size.Z / 2 + 5 then return false end

    -- Y: не провалился под Safe и не слишком высоко.
    local dy = charPos.Y - safePos.Y
    if dy < -5 then return false end
    if dy > size.Y / 2 + ScriptSettings.VerticalOffset + 10 then return false end

    return true
end

local function waitForCharacter()
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then
        char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        repeat task.wait() until char.PrimaryPart or char:FindFirstChild("HumanoidRootPart")
        if char and not char.PrimaryPart then
            char.PrimaryPart = char:FindFirstChild("HumanoidRootPart")
        end
        print("[Brainrot] Новая модель персонажа загружена")
    end
    return char
end

local farmLoopRunning = false
local function farmLoop()
    if farmLoopRunning then return end
    farmLoopRunning = true

    while ScriptSettings.AutoFarmEnabled do
        if isCycling then
            task.wait(0.2)
            continue
        end
        isCycling = true

        local character = waitForCharacter()

        if not getSafePartOrNil() then
            print("[Brainrot] Lobby.Safe не найден, ждём...")
            isCycling = false
            task.wait(1)
            continue
        end

        if firstRun then
            -- На первом запуске всегда телепортируемся над Safe,
            -- чтобы стартовать из заведомо корректной позиции.
            teleportWholeCharacter(character)
            task.wait(0.3)
            character = waitForCharacter()
            firstRun  = false
        end

        if not isAtSafe(character) then
            -- Вместо вечного ожидания — телепортируем обратно.
            print("[Brainrot] Персонаж не в Safe, телепортируем...")
            teleportWholeCharacter(character)
            task.wait(0.3)
            isCycling = false
            continue
        end

        local kickEvent = getKickEventOrNil()
        if not kickEvent then
            print("[Brainrot] rev_KickEvent не найден, ждём...")
            isCycling = false
            task.wait(1)
            continue
        end

        -- Прямо перед киком снапаем на саму поверхность Safe и обнуляем скорость,
        -- чтобы сервер гарантированно засчитал игрока как "в Safe" (иначе после smoothTeleport
        -- он оказывается в воздухе на verticalOffset, и кик работает раз через раз).
        snapToSafeSurface(character)
        task.wait(0.1)

        pcall(function() kickEvent:FireServer(1) end)
        print(("[Brainrot] KickEvent отправлен, ждём %d секунд..."):format(ScriptSettings.KickWaitSeconds))

        local waitStart = tick()
        while ScriptSettings.AutoFarmEnabled and tick() - waitStart < ScriptSettings.KickWaitSeconds do
            task.wait(0.1)
        end

        if ScriptSettings.AutoFarmEnabled then
            local currentChar = waitForCharacter()
            smoothTeleportCharacter(currentChar, ScriptSettings.SmoothTeleportDuration)
        end

        isCycling = false
    end

    farmLoopRunning = false
end

-- =====================================================================
-- BASE FUNCTION CORE (AutoCollect / AutoUpgrade)
-- =====================================================================
local MIN_PLACE = 1
local MAX_PLACE = 10

local function clampPlace(v)
    v = tonumber(v) or MIN_PLACE
    if v < MIN_PLACE then v = MIN_PLACE end
    if v > MAX_PLACE then v = MAX_PLACE end
    return math.floor(v)
end

local autoCollectLoopRunning = false
local function autoCollectLoop()
    if autoCollectLoopRunning then return end
    autoCollectLoopRunning = true
    while ScriptSettings.AutoCollectEnabled do
        local ev = getCollectEventOrNil()
        if ev then
            for i = MIN_PLACE, MAX_PLACE do
                if not ScriptSettings.AutoCollectEnabled then break end
                pcall(function() ev:FireServer(i) end)
                task.wait(0.05)
            end
        else
            print("[Base] rev_B_Collect не найден, ждём...")
        end
        task.wait(1)
    end
    autoCollectLoopRunning = false
end

local autoUpgradeLoopRunning = false
local function autoUpgradeLoop()
    if autoUpgradeLoopRunning then return end
    autoUpgradeLoopRunning = true
    while ScriptSettings.AutoUpgradeEnabled do
        local ev = getUpgradeEventOrNil()
        if ev then
            local place = clampPlace(ScriptSettings.AutoUpgradePlace)
            pcall(function() ev:FireServer(place) end)
        end
        task.wait(1)
    end
    autoUpgradeLoopRunning = false
end

