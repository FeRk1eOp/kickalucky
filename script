local useFS = false
do
    local hasFS = isfolder and makefolder and listfiles and writefile and readfile and delfile and isfile
    if hasFS then useFS = true end
end
getgenv()._KickALuckyConfigs  = getgenv()._KickALuckyConfigs or {}
local globalCfgs              = getgenv()._KickALuckyConfigs
local CFG_FOLDER              = "KickALuckyConfigs"

local function saveCfg(name, data)
    if useFS then
        if not isfolder(CFG_FOLDER) then makefolder(CFG_FOLDER) end
        return pcall(writefile, CFG_FOLDER.."/"..name..".json", HttpService:JSONEncode(data))
    else
        globalCfgs[name] = data
        return true
    end
end

local function loadCfg(name)
    if useFS then
        local ok, cont = pcall(readfile, CFG_FOLDER.."/"..name..".json")
        if ok and cont then
            local decoded
            local okDecode = pcall(function() decoded = HttpService:JSONDecode(cont) end)
            if okDecode then return decoded end
        end
        return nil
    else
        return globalCfgs[name]
    end
end

local function listCfgs()
    if useFS then
        if not isfolder(CFG_FOLDER) then return {} end
        local names = {}
        local ok, files = pcall(listfiles, CFG_FOLDER)
        if not ok or not files then return {} end
        for _, f in ipairs(files) do
            local n = f:match("([^/\\]+)%.json$")
            if n then table.insert(names, n) end
        end
        return names
    else
        local names = {}
        for n in pairs(globalCfgs) do table.insert(names, n) end
        return names
    end
end

local function delCfg(name)
    if useFS then
        if isfile(CFG_FOLDER.."/"..name..".json") then
            return pcall(delfile, CFG_FOLDER.."/"..name..".json")
        end
        return true
    else
        globalCfgs[name] = nil
        return true
    end
end

local function getAuto()
    if useFS then
        if isfolder(CFG_FOLDER) and isfile(CFG_FOLDER.."/autoload.txt") then
            local n = readfile(CFG_FOLDER.."/autoload.txt"):gsub("\n","")
            if n ~= "" then
                for _, c in ipairs(listCfgs()) do if c == n then return n end end
            end
        end
        return nil
    else
        return getgenv()._KickALuckyAutoload
    end
end

local function setAuto(name)
    if useFS then
        if not isfolder(CFG_FOLDER) then makefolder(CFG_FOLDER) end
        writefile(CFG_FOLDER.."/autoload.txt", name)
    else
        getgenv()._KickALuckyAutoload = name
    end
end

local function delAuto()
    if useFS then
        if isfolder(CFG_FOLDER) and isfile(CFG_FOLDER.."/autoload.txt") then
            delfile(CFG_FOLDER.."/autoload.txt")
        end
    else
        getgenv()._KickALuckyAutoload = nil
    end
end

local function createConfig(name)
    if name == nil or name == "" then return false end
    local data = {
        AutoFarmEnabled        = ScriptSettings.AutoFarmEnabled,
        VerticalOffset         = ScriptSettings.VerticalOffset,
        KickWaitSeconds        = ScriptSettings.KickWaitSeconds,
        SmoothTeleportDuration = ScriptSettings.SmoothTeleportDuration,
        AutoCollectEnabled     = ScriptSettings.AutoCollectEnabled,
        AutoUpgradeEnabled     = ScriptSettings.AutoUpgradeEnabled,
        AutoUpgradePlace       = ScriptSettings.AutoUpgradePlace,
        AutoBonusEnabled       = ScriptSettings.AutoBonusEnabled,
    }
    return saveCfg(name, data)
end

local function applySettingsToUI()
    if verticalStepper     then verticalStepper.setValue(ScriptSettings.VerticalOffset, true) end
    if kickWaitStepper     then kickWaitStepper.setValue(ScriptSettings.KickWaitSeconds, true) end
    if smoothStepper       then smoothStepper.setValue(ScriptSettings.SmoothTeleportDuration, true) end
    if autoFarmToggle      then autoFarmToggle.setValue(ScriptSettings.AutoFarmEnabled, true) end
    if autoCollectToggle   then autoCollectToggle.setValue(ScriptSettings.AutoCollectEnabled, true) end
    if autoUpgradeToggle   then autoUpgradeToggle.setValue(ScriptSettings.AutoUpgradeEnabled, true) end
    if upgradePlaceStepper then upgradePlaceStepper.setValue(ScriptSettings.AutoUpgradePlace, true) end
    if autoBonusToggle     then autoBonusToggle.setValue(ScriptSettings.AutoBonusEnabled, true) end
    updateStatusLabel()
end

local function loadConfig(name)
    local data = loadCfg(name)
    if type(data) ~= "table" then return false end

    if type(data.VerticalOffset)         == "number" then ScriptSettings.VerticalOffset         = data.VerticalOffset end
    if type(data.KickWaitSeconds)        == "number" then ScriptSettings.KickWaitSeconds        = data.KickWaitSeconds end
    if type(data.SmoothTeleportDuration) == "number" then ScriptSettings.SmoothTeleportDuration = data.SmoothTeleportDuration end
    if type(data.AutoUpgradePlace)       == "number" then ScriptSettings.AutoUpgradePlace       = clampPlace(data.AutoUpgradePlace) end

    local desiredFarm    = data.AutoFarmEnabled    == true
    local desiredCollect = data.AutoCollectEnabled == true
    local desiredUpgrade = data.AutoUpgradeEnabled == true
    local desiredBonus   = data.AutoBonusEnabled   == true

    applySettingsToUI()

    if desiredFarm and not ScriptSettings.AutoFarmEnabled then
        ScriptSettings.AutoFarmEnabled = true
        firstRun  = true
        isCycling = false
        if autoFarmToggle then autoFarmToggle.setValue(true, true) end
        updateStatusLabel()
        task.spawn(farmLoop)
    elseif (not desiredFarm) and ScriptSettings.AutoFarmEnabled then
        ScriptSettings.AutoFarmEnabled = false
        isCycling = false
        if autoFarmToggle then autoFarmToggle.setValue(false, true) end
        updateStatusLabel()
    end

    if desiredCollect and not ScriptSettings.AutoCollectEnabled then
        ScriptSettings.AutoCollectEnabled = true
        if autoCollectToggle then autoCollectToggle.setValue(true, true) end
        task.spawn(autoCollectLoop)
    elseif (not desiredCollect) and ScriptSettings.AutoCollectEnabled then
        ScriptSettings.AutoCollectEnabled = false
        if autoCollectToggle then autoCollectToggle.setValue(false, true) end
    end

    if desiredUpgrade and not ScriptSettings.AutoUpgradeEnabled then
        ScriptSettings.AutoUpgradeEnabled = true
        if autoUpgradeToggle then autoUpgradeToggle.setValue(true, true) end
        task.spawn(autoUpgradeLoop)
    elseif (not desiredUpgrade) and ScriptSettings.AutoUpgradeEnabled then
        ScriptSettings.AutoUpgradeEnabled = false
        if autoUpgradeToggle then autoUpgradeToggle.setValue(false, true) end
    end

    if desiredBonus and not ScriptSettings.AutoBonusEnabled then
        ScriptSettings.AutoBonusEnabled = true
        if autoBonusToggle then autoBonusToggle.setValue(true, true) end
        task.spawn(autoBonusLoop)
    elseif (not desiredBonus) and ScriptSettings.AutoBonusEnabled then
        ScriptSettings.AutoBonusEnabled = false
        if autoBonusToggle then autoBonusToggle.setValue(false, true) end
    end

    return true
end

